# Bench secrets — copy to bench/.env or export in shell (never commit)

# Isolated TEXT arm via OpenRouter (same model family as local /model)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=qwen/qwen3.5-35b-a3b

# Optional OpenRouter attribution headers
# OPENROUTER_HTTP_REFERER=https://github.com/umbecanessa/punk-records-inference
# OPENROUTER_APP_TITLE=Punk Records Inference Bench

# Local PRI instance for capture + RESUME / OVERFLOW arms
PRI_BASE_URL=http://127.0.0.1:8000
